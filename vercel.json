{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://t.me https://web.telegram.org"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-morning",
      "schedule": "30 4 * * *"
    }
  ]
}
